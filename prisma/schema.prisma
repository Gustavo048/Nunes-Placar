generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  
}

model Ranking {
  id          String   @id @default(cuid())
  teamName    String
  gameMode    GameMode   // ✅ agora tipado corretamente
  victories   Int        @default(0)
  totalPoints Int        @default(0)
  updatedAt   DateTime   @updatedAt

  @@unique([teamName, gameMode]) // ✅ ESSENCIAL pro upsert
}

enum GameMode {
  CANASTRA
  TRUCO
  DOMINO
}
