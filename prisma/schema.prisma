generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model User {
  id          String       @id @default(cuid())
  name        String
  email       String       @unique
  password    String
  role        UserRole     @default(USER)
  status      UserStatus   @default(PENDING)
  approvalToken String?      @unique
  rankings    Ranking[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Ranking {

  id           String       @id @default(cuid())
  teamName     String
  userId       String
  user         User         @relation(fields: [userId], references: [id])
  gameMode     GameMode
  victories    Int          @default(0)
  totalPoints  Int          @default(0)  
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  
  @@unique([teamName, gameMode])
  @@index([gameMode])
  @@index([teamName])
  @@index([victories])
  @@index([totalPoints])
}

enum GameMode {
  CANASTRA
  TRUCO
  DOMINO
}

enum UserRole {
  ADMIN
  USER
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}
