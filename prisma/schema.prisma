generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {

  id          String       @id @default(cuid())
  name        String
  email       String       @unique
  password    String
  role        UserRole     @default(USER)
  status      UserStatus   @default(PENDING)
  nickname     String?
  city         String?
  state        String?
  country      String?     @default("Brasil")
  favoriteGame GameMode?
  avatarUrl    String?
  bio          String?

  /* ADMIN CONTROL */

  blocked      Boolean      @default(false)
  blockedAt    DateTime?
  blockedBy    String?
  approvedAt   DateTime?
  approvedBy   String?

  /* ACTIVITY */
  isOnline     Boolean      @default(false)
  lastLoginAt  DateTime?
  lastSeenAt   DateTime?

  /* TOKENS */
  approvalToken            String?   @unique
  resetPasswordToken       String?   @unique
  resetPasswordExpiresAt   DateTime?

  /* RELATIONS */
  rankings     Ranking[]

  /* TIMESTAMPS */
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model AdminLog {

  id          String    @id @default(cuid())
  adminId     String
  action      String
  description String?
  targetId    String?
  ipAddress   String?
  createdAt   DateTime  @default(now())
}

model Ranking {
  id           String       @id @default(cuid())
  teamName     String
  userId       String
  user         User         @relation(fields: [userId], references: [id])
  gameMode     GameMode
  victories    Int          @default(0)
  totalPoints  Int          @default(0)
  matchCount   Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([teamName, gameMode])
  @@index([gameMode])
  @@index([teamName])
  @@index([victories])
  @@index([totalPoints])
}

model GuestUsage {
  id           String     @id @default(cuid())
  guestId      String     @unique
  gamesPlayed  Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

enum GameMode {
  CANASTRA
  TRUCO
  DOMINO
}

enum UserRole {
  ADMIN
  USER
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}


